{
  "name": "ai-foundation-csharp",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "22"
    },
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "lts"
    }
  },
  "remoteEnv": {
    "CODEX_SUBAGENTS_DIR": "${containerWorkspaceFolder}/awesome-codex-subagents"
  },
  "postCreateCommand": "/bin/bash .devcontainer/scripts/post-create.sh",
  "postStartCommand": "/bin/bash .devcontainer/csharp/post-start.sh",
  "forwardPorts": [
    1455
  ],
  "portsAttributes": {
    "1455": {
      "label": "Codex auth callback"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        "ms-dotnettools.vscode-dotnet-runtime"
      ]
    }
  }
}
